# Server Configuration
PORT=8080

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=mycourseville

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=3600

# MyCourseVille API Configuration
MYCOURSEVILLE_API_URL=https://www.mycourseville.com/api/v1
MYCOURSEVILLE_CLIENT_ID=your-client-id
MYCOURSEVILLE_CLIENT_SECRET=your-client-secret
